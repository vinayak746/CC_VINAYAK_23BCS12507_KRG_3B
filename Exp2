#include <bits/stdc++.h>
using namespace std;

int main() {
    int t; cin >> t;
    while (t--) {
        int n; cin >> n;
        vector<int> a(n);
        for (int &x : a) cin >> x;

        vector<int> freq(n + 1, 0);
        for (int x : a) freq[x]++;

        vector<bool> good(n + 1, false);

        for (int i = 0; i < n; i++) {
            int sum = a[i];
            for (int j = i + 1; j < n; j++) {
                sum += a[j];
                if (sum <= n) good[sum] = true;
            }
        }

        int ans = 0;
        for (int i = 1; i <= n; i++) {
            if (good[i]) ans += freq[i];
        }
        cout << ans << endl;
    }
}