#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, k;
    cin >> n >> k;

    vector<int> a(n);
    for (int &x : a) cin >> x;

    unordered_map<int,int> freq;
    int l = 0, ans = 0;

    for (int r = 0; r < n; r++) {
        freq[a[r]]++;

        while (freq[a[r]] > k) {
            freq[a[l]]--;
            l++;
        }

        ans = max(ans, r - l + 1);
    }

    cout << ans;
}