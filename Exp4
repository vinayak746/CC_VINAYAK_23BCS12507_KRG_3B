#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int nthMagicalNumber(int n, int a, int b) {
        long long l = 1, r = 1e18;
        long long lcm = (long long)a * b / __gcd(a, b);
        long long mod = 1e9 + 7;

        while (l < r) {
            long long mid = (l + r) / 2;
            long long count = mid / a + mid / b - mid / lcm;
            if (count >= n) r = mid;
            else l = mid + 1;
        }
        return l % mod;
    }
};